{
    "editor.formatOnSave": true,
    "python.terminal.activateEnvironment": false,
    "[python]": {
        "editor.defaultFormatter": "black"
    },
    "[cpp]": {
        "editor.defaultFormatter": "xaver.clang-format"
    },
    "files.associations": {
        "*.h": "cpp",
        "*.cpp": "cpp",
        "*.inc": "cpp",
        "*.cu": "cuda-cpp",
        "*.tcc": "cpp",
        "istream": "cpp",
        "tuple": "cpp",
        "array": "cpp",
        "functional": "cpp",
        "utility": "cpp",
        "future": "cpp",
        "memory": "cpp",
        "variant": "cpp",
        "locale": "cpp",
        "thread": "cpp",
        "chrono": "cpp",
        "complex": "cpp",
        "filesystem": "cpp",
        "typeinfo": "cpp",
        "typeindex": "cpp",
        "mutex": "cpp",
        "shared_mutex": "cpp",
        "__mutex_base": "cpp",
        "atomic": "cpp"
    }
}